# Copiar para .env (não versionar). Usado por Limpar-FilasRabbitMq.ps1
RABBITMQ_HOST=rabbitmq.sua-rede.local
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=alterar
# Virtual host na URL: "/" -> %2F
RABBITMQ_VHOST=%2F
# Só filas cujo nome contém (case-insensitive); vazio = todas as filas listadas (cuidado)
RABBITMQ_QUEUE_NAME_PREFIX=reprocess
