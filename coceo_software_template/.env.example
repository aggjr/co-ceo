# Raiz do frontend Vite (copie para .env e ajuste)

# Pasta no disco com index.html + app.js + style.css do STOCKSPIN espacial.
# O Vite (dev e preview) expõe em http://localhost:5173/physical-architecture/ (evita iframe file:// bloqueado).
# VITE_STOCKSPIN_PHYSICAL_ROOT=G:\Meu Drive\01 - Nova Estrutura\Trabalhos\FOCCUS\Softwares\STOCKSPIN

# Opcional: URL absoluta forçada (sobrepõe o proxy acima)
# VITE_PHYSICAL_ARCHITECTURE_INDEX_URL=http://127.0.0.1:5500/index.html
VITE_PHYSICAL_ARCHITECTURE_INDEX_URL=

# Base padrão dos HTML/JS estáticos do STOCKSPIN (quando o tenant não define module_settings)
# VITE_STOCKSPIN_STATIC_DEFAULT=http://localhost:8000
