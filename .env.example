# Copie para ".env" e preencha. Nunca commite o arquivo .env.
#
# MySQL local (stockspin / espelhos)
LOCAL_MYSQL_HOST=localhost
LOCAL_MYSQL_PORT=3306
LOCAL_MYSQL_USER=root
LOCAL_MYSQL_PASSWORD=
LOCAL_MYSQL_DATABASE=stockspin_db

# MySQL schema Co-CEO (snapshots / piloto)
CEO_MYSQL_HOST=localhost
CEO_MYSQL_PORT=3306
CEO_MYSQL_USER=root
CEO_MYSQL_PASSWORD=
CEO_MYSQL_DATABASE=ceo

# Legado produção (SSL na nuvem). Desligue SSL se usar túnel local na 3306.
LEGACY_MYSQL_HOST=
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_USER=
LEGACY_MYSQL_PASSWORD=
LEGACY_MYSQL_DATABASE=stockspin_core_db_saron
LEGACY_MYSQL_SSL=1
# true = validar certificado (CA); false = mesmo efeito que "ignorar verificação" no DBeaver
LEGACY_MYSQL_SSL_REJECT_UNAUTHORIZED=false
# Se o cliente mysqldump falhar ao ler o .cnf por causa de ssl-verify-server-cert, use LEGACY_SSL_VERIFY_CNF=0
# LEGACY_SSL_VERIFY_CNF=0
#
# apollo_grid_miner.js (Mix de Produtos): coluna de custo em `produto` para «R$ total em estoque». Vazio = auto (PrecoCusto, CustoMedio…).
# LEGACY_PRODUTO_CUSTO_COLUMN=PrecoCusto

# Réplica local do core legado (mysqldump | mysql). Padrão = mesmo nome do LEGACY_MYSQL_DATABASE.
# Para importar no schema do piloto Co-CEO (mesma instância): REPLICA_TARGET_DATABASE=ceo
REPLICA_TARGET_DATABASE=
# REPLICA_STRIP_DEFINER=1 — remove DEFINER de rotinas/views se der erro de permissão no import
# MYSQLDUMP_BIN= C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe
# MYSQL_BIN=

# seed_ceo_ranked_skus.js — por padrão ingere TODOS os SKUs (mais vendidos primeiro).
# SEED_TOP_SKUS=200 — opcional: limitar aos N primeiros do ranking
# SEED_LOG_EVERY=50 — log a cada N SKUs no console

# Pipeline Apollo a partir do legado (precisa LEGACY_* no .env):
#   npm run sync:catalog   → reindex_catalog.js (só lista ERP)
#   npm run sync:raw       → apollo_enterprise_miner.js (JSON em data/raw) — demorado
#   npm run sync:apollo-js → apollo_enterprise_engine.js (JS em data/js)
#   npm run sync:apollo-full → os três + build_client_network_matrix.js
#
# Rotina diária (tenant SARON — estado atual do legado):
#   npm run job:daily-from-legacy → sync:apollo-full + build:network-demands + build:cd-plan
#   npm run job:daily-9am        → só matriz + demandas + plano CD (rápido)
# Opcional antes da réplica local do schema legado: DAILY_REPLICATE_LEGACY=1
